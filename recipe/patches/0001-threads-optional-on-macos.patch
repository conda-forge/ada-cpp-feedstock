--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -131,8 +131,13 @@
     include(cmake/deps_gmsh.cmake)
     include(cmake/deps_ifc.cmake)

-    # Find Threads package for pthread support on Linux
-    find_package(Threads REQUIRED)
+    # Find Threads package for pthread support on Linux.
+    # On macOS pthread lives in libSystem (libc), so no separate threads
+    # library is needed; FindThreads' try_compile probes also misbehave under
+    # the conda-forge cross-compile toolchain, so only require it elsewhere.
+    if (NOT APPLE)
+        find_package(Threads REQUIRED)
+    endif ()
 endif ()

 if (BUILD_STP2GLB)
--- a/cmake/build_stp2glb.cmake
+++ b/cmake/build_stp2glb.cmake
@@ -24,7 +24,12 @@
 set_target_properties(STP2GLB PROPERTIES
         INSTALL_RPATH "${CMAKE_INSTALL_PREFIX}/bin"
 )
-target_link_libraries(STP2GLB ${ADA_CPP_LINK_LIBS} Threads::Threads)
+target_link_libraries(STP2GLB ${ADA_CPP_LINK_LIBS})
+# Threads::Threads only exists where find_package(Threads) ran (non-Apple);
+# on macOS pthread is part of libSystem and linked implicitly.
+if (TARGET Threads::Threads)
+    target_link_libraries(STP2GLB Threads::Threads)
+endif ()

 # install to executable into the bin dir
 # If EXE_BIN_DIR is not set, use root bin dir
